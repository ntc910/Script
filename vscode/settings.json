{
    "[windows]": {
        "code-runner.executorMap": {
            "cpp": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\cpp_run.ps1\" $fileName $dir",
            "html": "cd $dir && start $fileName",
            "csharp": "csc",
            "python": "python3",
            // "python": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\py_run.ps1\" $fileName $dir",
            "mk": "",
            "hpp": "$workspaceRoot/.vscode/cpp_run.sh $fileName $dir",
        },
    },
    "code-runner.executorMap": {
        "cpp": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\cpp_run.ps1\" $fileName $dir",
        "html": "cd $dir && start $fileName",
        "csharp": "csc",
        "python": "python3",
        // "python": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\py_run.ps1\" $fileName $dir",
        "mk": "",
        // "cpp": "$workspaceRoot/.vscode/cpp_run.sh $fileName $dir",
    },
    "code-runner.ignoreSelection": true,
    "[linux]": {
        "emmet.triggerExpansionOnTab": false, 
        "code-runner.executorMap": {
            "hpp": "$workspaceRoot/.vscode/cpp_run.sh $fileName $dir",
            "html": "cd $dir && start $fileName",
            "csharp": "csc",
            "python": "python3",
            // "python": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\py_run.ps1\" $fileName $dir",
            "mk": "",
        },
    },
    "code-runner.executorMapByFileExtension": {
        ".cpp": {
            "windows": "powershell -ExecutionPolicy ByPass -File \"$workspaceRoot\\.vscode\\cpp_run.ps1\" $fileName $dir",
            "linux": "$workspaceRoot/.vscode/cpp_run.sh $fileName $dir",
        }
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
    },
    "python.terminal.activateEnvironment": false,
    "editor.fontFamily": "Google Sans Mono",
    "terminal.integrated.fontFamily": "Google Sans Mono",
    "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 0, AllowShortIfStatementsOnASingleLine: AllIfsAndElse, AccessModifierOffset: 0}",
    "files.exclude": {
        "**/.git": false,
    },
    "fileHeaderComment.parameter": {
        "*": {
            "commentbegin": "/*",
            "commentprefix": " *",
            "takenote": "EN: clean code | KO: optimized code",
            "commentend": " */",
            "author": "NTC910"
        }
    },
    "fileHeaderComment.template": {
        "*": [
            "${commentbegin}",
            "${commentprefix} Created on ${date}",
            "${commentprefix} Copyright (c) ${author}",
            "${commentprefix} ${takenote}",
            "${commentend}"
        ]
    },
