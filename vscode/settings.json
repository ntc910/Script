    "editor.semanticTokenColorCustomizations": {
        "rules": {
            /*"keywords": {
                "foreground": "#10b1fe",
                "fontStyle": "italic"
            },*/
            "macro": {
                "foreground": "#b1ee56",
                "fontStyle": "italic"
            },
            "enumMember": "#9f7efe",
            "variable": "#d4d4d4",
            "property": "#ce9887",
            "memberOperatorOverload": "#d4d4d4",
            "*.local": {
                "foreground": "#d7d6a5",
                //"fontStyle": "underline",
            },
            "parameter": "#8bcdef"
        }
    },
    "editor.tokenColorCustomizations": {
        "comments": "#858d9e",
        "functions": "#44d675",
        "keywords": {
            //"foreground": "#10b1fe",
            "fontStyle": "italic"
        },
        "numbers": "#ff78f8",
        "strings": "#f9c859",
        "types": "#ff6480",
        "variables": "#d4d4d4",
        "textMateRules": [
            /*{
                "scope": "storage.modifier",
                "settings": {
                    "foreground": "#10b1fe",
                    "fontStyle": "italic"
                }
            },*/
            {
                "scope": "keyword.operator.arithmetic",
                "settings": {
                    "foreground": "#d4d4d4",
                }
            },
            {
                "scope": "keyword.control.directive",
                "settings": {
                    "foreground": "#49f8c7",
                    "fontStyle": "italic"
                }
            },
            /*{
                "scope": "keyword.other",
                "settings": {
                    "foreground": "#10b1fe",
                    "fontStyle": "italic"
                },
            },*/
            {
                "scope": "entity.name.function.preprocessor",
                "settings": {
                    "foreground": "#b1ee56",
                    "fontStyle": "italic"
                },
            },
            {
                "scope": [
                    "constant.other.placeholder",
                    "constant.language"
                ],
                "settings": {
                    "foreground": "#9f7efe",
                    "fontStyle": "italic"
                },
            },
            {
                "scope": "constant.character.escape",
                "settings": {
                    "foreground": "#ff936a",
                    "fontStyle": "italic"
                },
            },
            {
                "scope": "keyword.other.unit",
                "settings": {
                    "foreground": "#f9c859",
                    "fontStyle": "italic"
                },
            },
            {
                "scope": "constant.numeric.hexadecimal",
                "settings": {
                    "fontStyle": "italic"
                },
            },
        ],
    },
    "workbench.colorCustomizations": {
        "editorBracketHighlight.foreground1": "#92f535",
        "editorBracketHighlight.foreground2": "#28e4eb",
        "editorBracketHighlight.foreground3": "#ffa023",
        "editorBracketHighlight.foreground4": "#00ff95",
        "editorBracketHighlight.foreground5": "#ff78ff",
        "editorBracketHighlight.foreground6": "#ffffff"
    },
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": false,
    "editor.formatOnType": false,
    "editor.wordWrap": "on",
    "code-runner.runInTerminal": true,
    "code-runner.showExecutionMessage": true,
    "[java]": {
        "editor.defaultFormatter": "redhat.java"
    },
    "[html]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false
    },
    "cmake.ignoreCMakeListsMissing": true,
    "java.debug.settings.onBuildFailureProceed": true,
    // "python.languageServer": "None",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        }
    }
